generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与认证 ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions Session[]
  projects Project[]  @relation("CreatedProjects")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==================== 项目管理 ====================

model Project {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  logo         String?
  description  String?
  tags         String[]
  status       String   @default("待立项")
  valuation    String?
  round        String?
  ownerId      String?  @map("owner_id")
  ownerName    String?  @map("owner_name")
  strategyId   String?  @map("strategy_id")
  strategyName String?  @map("strategy_name")
  creatorId    String   @map("creator_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  creator   User       @relation("CreatedProjects", fields: [creatorId], references: [id], onDelete: Cascade)
  tasks     Task[]
  documents Document[]

  @@index([code])
  @@index([status])
  @@index([ownerId])
  @@index([strategyId])
  @@index([createdAt])
  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  title       String
  description String?
  status      String    @default("pending")
  priority    String?   @default("中")
  assignee    String?
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Document {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  format    String?
  size      String?
  category  String?
  url       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documents")
}
