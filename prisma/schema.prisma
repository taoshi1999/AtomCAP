generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  logo         String?
  description  String?
  tags         String[]
  status       String   @default("待立项")
  valuation    String?
  round        String?
  ownerId      String?
  ownerName    String?
  strategyId   String?
  strategyName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("projects")
}